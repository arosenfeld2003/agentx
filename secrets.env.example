# Copy to /opt/agentx/secrets.env on the VPS (chmod 600, never commit)
ANTHROPIC_API_KEY=sk-ant-...

# Hostinger mail (agentx@runggp.com)
IMAP_HOST=imap.hostinger.com
IMAP_PORT=993
IMAP_USER=agentx@runggp.com
IMAP_PASS=

SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=agentx@runggp.com
SMTP_PASS=

# Comma-separated list of email addresses allowed to send tasks (leave blank to allow all)
AGENTX_ALLOWED_SENDERS=
# Ralph subprocess timeout in seconds (default: 1800 = 30 minutes)
AGENTX_RALPH_TIMEOUT=1800

# Spend ceiling per session in USD (default: 0 = disabled). Loop stops and sends
# a notification email when cumulative cost reaches this value.
RALPH_SPEND_CEILING_USD=0

# Phase 2: Local models via LiteLLM proxy (uncomment after Ollama is installed)
# LITELLM_MASTER_KEY=change-me-random-secret
# ANTHROPIC_BASE_URL=http://localhost:4000
# To use local model, also set RALPH_MODEL=qwen3:8b in vps-compose.yml
# To revert to Claude API: remove ANTHROPIC_BASE_URL, set RALPH_MODEL=claude-sonnet-4-6
